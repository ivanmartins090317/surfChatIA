# URL pública do app (redirects de auth Supabase)
# Local: http://localhost:3000
# Vercel: https://seu-projeto.vercel.app (obrigatório em produção)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — variáveis públicas (browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# anon key (legado) ou publishable key (dashboard novo: sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Supabase — server-only
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Senha Postgres (Settings → Database) — só CLI/migrations, nunca commitar valor real
SUPABASE_DB_PASSWORD=your-database-password

# OpenAI — server-only (análises IA)
OPENAI_API_KEY=sk-your-key

# Admin — promover primeiro admin manualmente no Supabase SQL Editor:
# update public.profiles set role = 'admin' where id = '<uuid-do-usuario>';
